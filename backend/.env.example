# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
PORT=8000

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
# Project Settings → API → "JWT Secret" (HS256). Required to verify user JWTs.
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (email notifications) ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Admin / ops ──────────────────────────────────────────────────────────────
# Required to call POST /api/v1/scraper/run. Send as `X-Admin-Token` header.
ADMIN_TOKEN=replace-me-with-a-long-random-string

# ── Rate limits (daily, resets at 00:00 UTC) ─────────────────────────────────
RATE_LIMIT_ANON_PER_DAY=3
RATE_LIMIT_USER_PER_DAY=7
